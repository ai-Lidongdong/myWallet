{
  "name": "mywallet",
  "displayName": "myWallet",
  "version": "1.0.0",
  "description": "Plasmo browser extension starter",
  "manifest": {
    "name": "myWallet",
    "permissions": [
      "storage",
      "tabs",
      "scripting"
    ],
    "host_permissions": [
      "<all_urls>"
    ]
  },
  "proxy": "https://www.lidongdong.top",
  "scripts": {
    "dev": "PLASMO_DISABLE_VERSION_CHECK=1 plasmo dev --target=chrome-mv3 --src-path=src",
    "dev:watch": "PLASMO_DISABLE_VERSION_CHECK=1 plasmo dev --target=chrome-mv3 --src-path=src",
    "dev:watch:reset": "rm -rf .plasmo build && PLASMO_DISABLE_VERSION_CHECK=1 plasmo dev --target=chrome-mv3 --src-path=src",
    "build": "PLASMO_DISABLE_VERSION_CHECK=1 plasmo build --target=chrome-mv3 --src-path=src",
    "package": "npm run dist",
    "dist": "npm run build && rm -rf dist && mkdir -p dist/chrome && cp -R build/chrome-mv3-prod/. dist/chrome && node -e \"const fs=require('fs');const p='dist/chrome/manifest.json';const m=JSON.parse(fs.readFileSync(p,'utf8'));m.name='myWallet';if(!m.description)m.description='myWallet extension';fs.writeFileSync(p,JSON.stringify(m));\" && ditto -c -k --sequesterRsrc --keepParent dist/chrome dist/mywallet-chrome.zip"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "axios": "^1.14.0",
    "bip39": "^3.1.0",
    "crypto-js": "^4.2.0",
    "ethers": "^6.16.0",
    "plasmo": "^0.90.5",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.13.2",
    "typescript": "^6.0.2",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@types/chrome": "^0.1.38",
    "autoprefixer": "^10.4.27",
    "postcss": "^8.5.8",
    "svgo": "^3.3.3",
    "tailwindcss": "^3.4.19"
  }
}
